{
  "id": "hpcfund-cluster-observability",
  "name": "HPCFund Cluster Observability",
  "description": "Historical observability domain for the HPCFund GPU cluster, combining ROCm telemetry, Slurm scheduler state, node-exporter metrics, InfiniBand health, and job-to-node correlation from March 2026.",
  "color": "#8df0c6",
  "icon": "HF",
  "allowedArchetypes": [
    "risk-scoreboard",
    "pressure-board",
    "timeline-analysis",
    "correlation-inspector",
    "incident-summary",
    "job-detail-sheet"
  ],
  "dataSources": [
    "victoria-cluster"
  ],
  "analysisRecipe": {
    "focus": "Summarize the broadest cluster operating picture from the historical VictoriaMetrics evidence.",
    "blocks": [
      {
        "id": "instrumented-host-count",
        "title": "Instrumented Hosts",
        "operation": "scalar",
        "queryName": "instrumentedHostCount",
        "valueField": "hostCount",
        "unit": "hosts"
      },
      {
        "id": "cluster-backlog",
        "title": "Partition Backlog",
        "operation": "top_entries",
        "queryName": "pendingJobsByPartition",
        "labelFields": [
          "partition"
        ],
        "valueField": "pendingJobs",
        "limit": 3,
        "sort": "desc"
      },
      {
        "id": "cluster-thermal-outliers",
        "title": "Thermal Outliers",
        "operation": "top_entries",
        "queryName": "hotGpusByTemperature",
        "labelFields": [
          "instance",
          "card"
        ],
        "valueField": "temperatureC",
        "unit": "C",
        "limit": 3,
        "sort": "desc"
      },
      {
        "id": "cluster-fabric-risk",
        "title": "Fabric Risk",
        "operation": "top_entries",
        "queryName": "ibErrorScoreByNode",
        "labelFields": [
          "instance"
        ],
        "valueField": "errorScore",
        "limit": 3,
        "sort": "desc"
      }
    ]
  },
  "panels": [
    {
      "id": "fleet-health",
      "title": "Fleet Health",
      "summary": "Rank hosts by operational risk using node state, SMART, InfiniBand, scheduler, and GPU fault signals across the historical window.",
      "analysisPrompt": "Using the VictoriaMetrics historical window, assess overall cluster health for hpcfund. Identify the highest-risk hosts, explain whether the dominant risks are scheduler, hardware, fabric, or thermal, and call out where evidence is weak versus strong.",
      "chartPreference": "bar",
      "allowedArchetypes": [
        "risk-scoreboard",
        "incident-summary"
      ],
      "preferredArchetype": "risk-scoreboard",
      "archetypeGuidance": "Prefer risk-scoreboard when concrete host ranking is strong. Fall back to incident-summary when evidence is mixed or mostly narrative.",
      "analysisRecipe": {
        "focus": "Rank hosts by cluster health risk using scheduler, storage, fabric, GPU fault, and thermal evidence.",
        "blocks": [
          {
            "id": "instrumented-host-count",
            "title": "Instrumented Hosts",
            "operation": "scalar",
            "queryName": "instrumentedHostCount",
            "valueField": "hostCount",
            "unit": "hosts"
          },
          {
            "id": "node-health-risk",
            "title": "Node Health Risk",
            "operation": "top_entries",
            "queryName": "slurmNodeHealthScore",
            "labelFields": [
              "instance"
            ],
            "valueField": "healthScore",
            "limit": 5,
            "sort": "desc"
          },
          {
            "id": "storage-failures",
            "title": "SMART Failures",
            "operation": "top_entries",
            "queryName": "smartFailures",
            "labelFields": [
              "instance",
              "device"
            ],
            "valueField": "failures",
            "limit": 4,
            "sort": "desc"
          },
          {
            "id": "fabric-risk",
            "title": "Fabric Risk",
            "operation": "top_entries",
            "queryName": "ibErrorScoreByNode",
            "labelFields": [
              "instance"
            ],
            "valueField": "errorScore",
            "limit": 4,
            "sort": "desc"
          },
          {
            "id": "gpu-thermal-risk",
            "title": "GPU Thermal Risk",
            "operation": "top_entries",
            "queryName": "hotGpusByTemperature",
            "labelFields": [
              "instance",
              "card"
            ],
            "valueField": "temperatureC",
            "unit": "C",
            "limit": 4,
            "sort": "desc"
          }
        ]
      }
    },
    {
      "id": "scheduler-pressure",
      "title": "Scheduler Pressure",
      "summary": "Explain partition saturation, pending demand, and where the queue is likely to be constraining users.",
      "analysisPrompt": "Analyze scheduler pressure by partition. Explain which GPU families are saturated, where pending jobs are concentrated, and what that implies about capacity bottlenecks or scheduling imbalance.",
      "chartPreference": "bar",
      "allowedArchetypes": [
        "pressure-board",
        "incident-summary"
      ],
      "preferredArchetype": "pressure-board",
      "archetypeGuidance": "Choose pressure-board when partition backlog and saturation metrics are clear. Use incident-summary only when the evidence is mostly textual.",
      "analysisRecipe": {
        "focus": "Explain scheduler bottlenecks through backlog and saturation signals by partition.",
        "blocks": [
          {
            "id": "partition-backlog",
            "title": "Pending Jobs By Partition",
            "operation": "top_entries",
            "queryName": "pendingJobsByPartition",
            "labelFields": [
              "partition"
            ],
            "valueField": "pendingJobs",
            "limit": 6,
            "sort": "desc"
          },
          {
            "id": "partition-saturation",
            "title": "Partition CPU Saturation",
            "operation": "top_entries",
            "queryName": "partitionCpuSaturation",
            "labelFields": [
              "partition"
            ],
            "valueField": "saturationPercent",
            "valueTransform": "percent",
            "unit": "percent",
            "decimals": 0,
            "limit": 6,
            "sort": "desc"
          },
          {
            "id": "instrumented-host-count",
            "title": "Instrumented Hosts",
            "operation": "scalar",
            "queryName": "instrumentedHostCount",
            "valueField": "hostCount",
            "unit": "hosts"
          }
        ]
      }
    },
    {
      "id": "gpu-hotspots",
      "title": "GPU Hotspots",
      "summary": "Focus on ROCm temperature, utilization, VRAM pressure, and power signals to find the most stressed accelerators.",
      "analysisPrompt": "Find the hottest or most stressed GPUs in the historical window. Correlate temperature, GPU activity, and any relevant host context, and explain which accelerators deserve investigation first.",
      "chartPreference": "line",
      "allowedArchetypes": [
        "timeline-analysis",
        "risk-scoreboard"
      ],
      "preferredArchetype": "timeline-analysis",
      "archetypeGuidance": "Use timeline-analysis when temporal or trend framing is meaningful. Use risk-scoreboard when the story is primarily ranked outliers.",
      "analysisRecipe": {
        "focus": "Identify the most stressed GPUs through thermal, utilization, VRAM, and occupancy signals.",
        "blocks": [
          {
            "id": "thermal-hotspots",
            "title": "Thermal Hotspots",
            "operation": "top_entries",
            "queryName": "hotGpusByTemperature",
            "labelFields": [
              "instance",
              "card"
            ],
            "valueField": "temperatureC",
            "unit": "C",
            "limit": 6,
            "sort": "desc"
          },
          {
            "id": "utilization-peaks",
            "title": "GPU Utilization Peaks",
            "operation": "top_entries",
            "queryName": "jobGpuUtilizationPeak",
            "labelFields": [
              "user",
              "jobid",
              "instance"
            ],
            "valueField": "utilizationPercent",
            "limit": 5,
            "sort": "desc"
          },
          {
            "id": "vram-peaks",
            "title": "GPU VRAM Peaks",
            "operation": "top_entries",
            "queryName": "jobGpuVramPeak",
            "labelFields": [
              "user",
              "jobid",
              "instance"
            ],
            "valueField": "vramPercent",
            "limit": 5,
            "sort": "desc"
          },
          {
            "id": "occupancy-peaks",
            "title": "Compute Occupancy Peaks",
            "operation": "top_entries",
            "queryName": "jobGpuOccupancyPeak",
            "labelFields": [
              "user",
              "jobid",
              "instance"
            ],
            "valueField": "occupancy",
            "limit": 5,
            "sort": "desc"
          }
        ]
      }
    },
    {
      "id": "fabric-storage",
      "title": "Fabric And Storage",
      "summary": "Surface InfiniBand anomalies and SMART health issues that can affect throughput or reliability.",
      "analysisPrompt": "Analyze InfiniBand and storage-health signals. Identify nodes with unusual fabric error behavior or SMART failures, explain likely operator impact, and separate probable noise from meaningful degradation.",
      "chartPreference": "bar",
      "allowedArchetypes": [
        "risk-scoreboard",
        "incident-summary"
      ],
      "preferredArchetype": "risk-scoreboard",
      "archetypeGuidance": "Prefer ranked diagnostics when error counters clearly isolate a few nodes. Use incident-summary when evidence is sparse.",
      "analysisRecipe": {
        "focus": "Surface the infrastructure nodes most exposed to fabric or storage degradation.",
        "blocks": [
          {
            "id": "fabric-risk",
            "title": "InfiniBand Error Leaders",
            "operation": "top_entries",
            "queryName": "ibErrorScoreByNode",
            "labelFields": [
              "instance"
            ],
            "valueField": "errorScore",
            "limit": 5,
            "sort": "desc"
          },
          {
            "id": "storage-failures",
            "title": "SMART Failures",
            "operation": "top_entries",
            "queryName": "smartFailures",
            "labelFields": [
              "instance",
              "device"
            ],
            "valueField": "failures",
            "limit": 5,
            "sort": "desc"
          },
          {
            "id": "node-health-risk",
            "title": "Node Health Risk",
            "operation": "top_entries",
            "queryName": "slurmNodeHealthScore",
            "labelFields": [
              "instance"
            ],
            "valueField": "healthScore",
            "limit": 4,
            "sort": "desc"
          }
        ]
      }
    },
    {
      "id": "job-correlation",
      "title": "Job Correlation",
      "summary": "Connect stressed nodes back to partitions, users, and jobs so operators can understand what workload context explains the telemetry.",
      "analysisPrompt": "Use scheduler and job metadata to connect hot or problematic nodes to likely workload causes. Summarize which partitions and users appear associated with the most stressed parts of the cluster, and note any ambiguity in the evidence.",
      "chartPreference": "donut",
      "allowedArchetypes": [
        "correlation-inspector",
        "incident-summary"
      ],
      "preferredArchetype": "correlation-inspector",
      "archetypeGuidance": "Prefer correlation-inspector when there are clear host-user-job-partition relationships. Fall back to incident-summary when attribution is weak.",
      "analysisRecipe": {
        "focus": "Connect hot or problematic infrastructure to jobs, users, and partitions using node-level workload evidence.",
        "blocks": [
          {
            "id": "recent-jobs",
            "title": "Recent Jobs By Node",
            "operation": "top_entries",
            "queryName": "recentJobsByNode",
            "labelFields": [
              "user",
              "jobid",
              "partition",
              "instance"
            ],
            "valueField": "presence",
            "limit": 6,
            "sort": "desc"
          },
          {
            "id": "job-utilization-peaks",
            "title": "Job GPU Utilization Peaks",
            "operation": "top_entries",
            "queryName": "jobGpuUtilizationPeak",
            "labelFields": [
              "user",
              "jobid",
              "partition",
              "instance"
            ],
            "valueField": "utilizationPercent",
            "limit": 5,
            "sort": "desc"
          },
          {
            "id": "job-vram-peaks",
            "title": "Job GPU VRAM Peaks",
            "operation": "top_entries",
            "queryName": "jobGpuVramPeak",
            "labelFields": [
              "user",
              "jobid",
              "partition",
              "instance"
            ],
            "valueField": "vramPercent",
            "limit": 5,
            "sort": "desc"
          }
        ]
      }
    },
    {
      "id": "job-explorer",
      "title": "Job Explorer",
      "summary": "Investigate specific Slurm jobs and infer how GPU utilization, occupancy, and VRAM demand changed over the job lifetime or visible window.",
      "analysisPrompt": "Use rmsjob_info and the ROCm telemetry series to build a job-centric view. Identify specific jobs that can be tied to nodes with strong GPU demand signals, summarize which users and partitions they belong to, and explain how GPU utilization, compute-unit occupancy, VRAM use, power, or thermal behavior appear to fluctuate over the visible window. Be explicit about when attribution is direct versus inferred from node-level overlap.",
      "chartPreference": "line",
      "allowedArchetypes": [
        "job-detail-sheet",
        "timeline-analysis",
        "correlation-inspector"
      ],
      "interactionMode": "hybrid",
      "interactionContract": {
        "summary": "Allow the operator to drill into specific jobs, partitions, hosts, and date windows without regenerating the widget.",
        "controls": [
          {
            "id": "job-selector",
            "label": "Jobs",
            "description": "Select one or more Slurm jobs from the visible workload evidence.",
            "type": "multi_select",
            "parameter": "jobIds",
            "source": "label_values",
            "queryName": "recentJobsByNode",
            "field": "jobid",
            "displayFields": [
              "user",
              "jobid",
              "partition",
              "instance"
            ],
            "maxOptions": 18,
            "multiple": true,
            "defaultStrategy": "none"
          },
          {
            "id": "partition-selector",
            "label": "Partitions",
            "description": "Filter the job view by partition.",
            "type": "multi_select",
            "parameter": "partitions",
            "source": "label_values",
            "queryName": "recentJobsByNode",
            "field": "partition",
            "displayFields": [
              "partition"
            ],
            "maxOptions": 12,
            "multiple": true,
            "defaultStrategy": "none"
          },
          {
            "id": "instance-selector",
            "label": "Hosts",
            "description": "Limit the view to selected hosts.",
            "type": "multi_select",
            "parameter": "instances",
            "source": "label_values",
            "queryName": "recentJobsByNode",
            "field": "instance",
            "displayFields": [
              "instance"
            ],
            "maxOptions": 16,
            "multiple": true,
            "defaultStrategy": "none"
          },
          {
            "id": "window-selector",
            "label": "Date Range",
            "description": "Re-query the visible analysis window for the selected job view.",
            "type": "date_range",
            "parameter": "dateRange",
            "source": "query_window",
            "multiple": false,
            "defaultStrategy": "top"
          }
        ]
      },
      "preferredArchetype": "job-detail-sheet",
      "archetypeGuidance": "Use job-detail-sheet when the analysis can focus on a few jobs. Use timeline-analysis for behavior-over-window stories and correlation-inspector for broader workload attribution.",
      "analysisRecipe": {
        "focus": "Build a job-centric evidence pack that highlights specific jobs and their GPU demand signatures.",
        "blocks": [
          {
            "id": "recent-jobs",
            "title": "Recent Jobs By Node",
            "operation": "top_entries",
            "queryName": "recentJobsByNode",
            "labelFields": [
              "user",
              "jobid",
              "partition",
              "instance"
            ],
            "valueField": "presence",
            "limit": 6,
            "sort": "desc"
          },
          {
            "id": "utilization-peaks",
            "title": "GPU Utilization Peaks",
            "operation": "top_entries",
            "queryName": "jobGpuUtilizationPeak",
            "labelFields": [
              "user",
              "jobid",
              "partition",
              "instance"
            ],
            "valueField": "utilizationPercent",
            "limit": 6,
            "sort": "desc"
          },
          {
            "id": "vram-peaks",
            "title": "GPU VRAM Peaks",
            "operation": "top_entries",
            "queryName": "jobGpuVramPeak",
            "labelFields": [
              "user",
              "jobid",
              "partition",
              "instance"
            ],
            "valueField": "vramPercent",
            "limit": 6,
            "sort": "desc"
          },
          {
            "id": "occupancy-peaks",
            "title": "Compute Occupancy Peaks",
            "operation": "top_entries",
            "queryName": "jobGpuOccupancyPeak",
            "labelFields": [
              "user",
              "jobid",
              "partition",
              "instance"
            ],
            "valueField": "occupancy",
            "limit": 6,
            "sort": "desc"
          },
          {
            "id": "thermal-context",
            "title": "Thermal Context",
            "operation": "top_entries",
            "queryName": "hotGpusByTemperature",
            "labelFields": [
              "instance",
              "card"
            ],
            "valueField": "temperatureC",
            "unit": "C",
            "limit": 4,
            "sort": "desc"
          }
        ]
      }
    },
    {
      "id": "operator-brief",
      "title": "Operator Brief",
      "summary": "Produce a shift-handoff summary with the most important actions, watch items, and notable evidence.",
      "analysisPrompt": "Generate a concise cluster-operations handoff brief for hpcfund. Include urgent actions, watch items, scheduler pressure summary, hardware/fabric notes, and confidence caveats given that this dataset is historical rather than live.",
      "chartPreference": "donut",
      "allowedArchetypes": [
        "incident-summary",
        "risk-scoreboard"
      ],
      "preferredArchetype": "incident-summary",
      "archetypeGuidance": "Prefer incident-summary for handoff-oriented communication. Use risk-scoreboard only when the brief is driven by a very clear ranked set of risks.",
      "analysisRecipe": {
        "focus": "Assemble the most important handoff evidence across scheduler, thermal, fabric, storage, and workload signals.",
        "blocks": [
          {
            "id": "brief-backlog",
            "title": "Backlog Leaders",
            "operation": "top_entries",
            "queryName": "pendingJobsByPartition",
            "labelFields": [
              "partition"
            ],
            "valueField": "pendingJobs",
            "limit": 3,
            "sort": "desc"
          },
          {
            "id": "brief-saturation",
            "title": "Saturation Leaders",
            "operation": "top_entries",
            "queryName": "partitionCpuSaturation",
            "labelFields": [
              "partition"
            ],
            "valueField": "saturationPercent",
            "valueTransform": "percent",
            "unit": "percent",
            "decimals": 0,
            "limit": 3,
            "sort": "desc"
          },
          {
            "id": "brief-thermal",
            "title": "Thermal Leaders",
            "operation": "top_entries",
            "queryName": "hotGpusByTemperature",
            "labelFields": [
              "instance",
              "card"
            ],
            "valueField": "temperatureC",
            "unit": "C",
            "limit": 3,
            "sort": "desc"
          },
          {
            "id": "brief-fabric",
            "title": "Fabric Leaders",
            "operation": "top_entries",
            "queryName": "ibErrorScoreByNode",
            "labelFields": [
              "instance"
            ],
            "valueField": "errorScore",
            "limit": 3,
            "sort": "desc"
          },
          {
            "id": "brief-jobs",
            "title": "Recent Jobs",
            "operation": "top_entries",
            "queryName": "recentJobsByNode",
            "labelFields": [
              "user",
              "jobid",
              "partition",
              "instance"
            ],
            "valueField": "presence",
            "limit": 4,
            "sort": "desc"
          }
        ]
      }
    }
  ]
}
