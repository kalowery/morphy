{
  "app": {
    "name": "Morphy",
    "tagline": "Adaptive analytics for heterogeneous data domains",
    "refreshIntervalMs": 15000,
    "listenPort": 3000,
    "defaultDomainId": "hpcfund-cluster-observability"
  },
  "agent": {
    "model": "gpt-5.4",
    "reasoningEffort": "medium",
    "allowBackground": true
  },
  "codegen": {
    "model": "gpt-5.4",
    "reasoningEffort": "medium",
    "sandboxMode": "iframe"
  },
  "refresh": {
    "schedulerTickMs": 60000,
    "sourcePreviewTtlMs": 60000,
    "workspacePlanTtlMs": 300000,
    "analysisTtlMs": 300000,
    "panelsPerSweep": 3
  },
  "diagnostics": {
    "server": {
      "enabled": true,
      "level": "info",
      "categories": [
        "server",
        "refresh",
        "analysis",
        "planner",
        "widgets",
        "datasources"
      ],
      "maxFieldLength": 320
    },
    "client": {
      "enabled": true,
      "level": "info",
      "categories": [
        "app",
        "render",
        "events",
        "widgets",
        "network"
      ],
      "maxFieldLength": 240
    }
  }
}
